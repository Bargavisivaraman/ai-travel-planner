# Copy to .env and fill in real values for production.

# PostgreSQL connection string (Neon / Vercel Postgres / Supabase / local)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/travelplanner?schema=public"

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"
# Public base URL of the deployed app
NEXTAUTH_URL="http://localhost:3000"

# OpenAI API key (optional). Without it, a deterministic itinerary engine is used.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
