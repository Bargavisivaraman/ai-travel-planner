{
  "name": "ai-travel-planner",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered travel planning platform: generate, customize, save and share trip itineraries.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
